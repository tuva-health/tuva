#!/usr/bin/env python3
"""Publish Tuva DoltHub databases to versioned S3 seed artifacts."""

from __future__ import annotations

import argparse
import csv
import gzip
import http.client
import io
import json
import os
import shutil
import socket
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.request
from dataclasses import asdict, dataclass
from functools import lru_cache
from pathlib import Path
from typing import Iterable
import re

try:
    import yaml
except ImportError as exc:
    raise RuntimeError("PyYAML is required to run publish-dolthub-seeds.") from exc


DEFAULT_OWNER = "tuva-health"
DEFAULT_REF = "main"
DEFAULT_BUCKET = "tuva-public-resources"
HTTP_TIMEOUT_SECONDS = int(os.getenv("TUVA_DOLTHUB_HTTP_TIMEOUT_SECONDS", "900"))

DATABASE_FOLDERS = {
    "concept_library": "concept-library",
    "reference_data": "reference-data",
    "terminology": "terminology",
    "value_sets": "value-sets",
    "provider_data": "provider-data",
    "synthetic_data": "synthetic-data",
}

REPO_TO_LOGICAL_DATABASE = {repo: logical for logical, repo in DATABASE_FOLDERS.items()}
LOCAL_REPO_DIRS = {
    "concept-library": "tuva-concept-library",
    "reference-data": "tuva-reference-data",
    "terminology": "tuva-terminology",
    "value-sets": "tuva-value-sets",
    "provider-data": "provider-data",
    "synthetic-data": "tuva-synthetic-data",
}

SYNTHETIC_TABLE_TO_SEED_MODEL = {
    "appointment": "raw_data__appointment",
    "appointment_small": "raw_data__appointment",
    "eligibility": "raw_data__eligibility",
    "eligibility_small": "raw_data__eligibility",
    "immunization": "raw_data__immunization",
    "lab_result": "raw_data__lab_result",
    "medical_claim": "raw_data__medical_claim",
    "medical_claim_small": "raw_data__medical_claim",
    "observation": "raw_data__observation",
    "pharmacy_claim": "raw_data__pharmacy_claim",
    "pharmacy_claim_small": "raw_data__pharmacy_claim",
    "provider_attribution": "raw_data__provider_attribution",
}

HOOK_PATTERN = re.compile(
    r"load_versioned_seed\('([^']+)'\s*,\s*'([^']+)'\)"
)
DATE_VALUE_PATTERN = re.compile(r"^(\d{4}-\d{2}-\d{2})(?:[ T].*)$")


@dataclass(frozen=True)
class TableAsset:
    logical_database: str
    repo_database: str
    table_name: str
    expected_rows: int

    @property
    def relative_key(self) -> str:
        return f"{self.repo_database}/{ARGS.version}/{self.table_name}.csv.gz"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Download the latest Tuva seed tables from public DoltHub repositories and "
            "publish them to versioned S3 folders."
        )
    )
    parser.add_argument(
        "--version",
        required=True,
        help="Release version to publish, e.g. v1.0.0 or 1.0.0.",
    )
    parser.add_argument(
        "--owner",
        default=DEFAULT_OWNER,
        help=f"DoltHub owner or organization. Defaults to {DEFAULT_OWNER}.",
    )
    parser.add_argument(
        "--ref",
        default=DEFAULT_REF,
        help=f"DoltHub ref to read from. Defaults to {DEFAULT_REF}.",
    )
    parser.add_argument(
        "--source",
        choices=["dolthub", "local"],
        default="dolthub",
        help="Seed export source. Defaults to dolthub.",
    )
    parser.add_argument(
        "--local-repo-root",
        default=str(Path("/Users/aaronneiderhiser/code")),
        help="Root folder containing local Dolt clones when --source local is used.",
    )
    parser.add_argument(
        "--local-ref",
        help=(
            "Optional Dolt ref to read from when --source local is used, "
            "for example main, tuva_health/main, or a commit hash."
        ),
    )
    parser.add_argument(
        "--database",
        action="append",
        default=[],
        help=(
            "Optional logical database filter. Repeat for multiple values. "
            "Accepted values: concept_library, reference_data, terminology, "
            "value_sets, provider_data, synthetic_data."
        ),
    )
    parser.add_argument(
        "--table",
        action="append",
        default=[],
        help=(
            "Optional exact table-name filter. Repeat for multiple values. "
            "Applied after database selection."
        ),
    )
    parser.add_argument(
        "--bucket",
        action="append",
        default=[],
        help=(
            "Optional S3 bucket override in the form logical_database=bucket-or-bucket/prefix. "
            "Defaults to tuva-public-resources for any database not listed."
        ),
    )
    parser.add_argument(
        "--stage-dir",
        help="Optional directory for staged gzip files and manifest output.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the publish plan without downloading or uploading anything.",
    )
    parser.add_argument(
        "--download-only",
        action="store_true",
        help="Download and validate locally without uploading to S3.",
    )
    parser.add_argument(
        "--keep-staged-files",
        action="store_true",
        help="Keep staged files after the script finishes. Requires --stage-dir.",
    )
    return parser.parse_args()


def normalize_version(version: str) -> str:
    normalized = version.strip()
    if normalized.startswith("v"):
        normalized = normalized[1:]
    if not normalized:
        raise ValueError("Version cannot be empty.")
    return normalized


def normalize_database_name(raw_name: str) -> str:
    name = raw_name.strip()
    name = name.replace("-", "_")
    if name in DATABASE_FOLDERS:
        return name
    if raw_name in REPO_TO_LOGICAL_DATABASE:
        return REPO_TO_LOGICAL_DATABASE[raw_name]
    raise ValueError(
        f"Unsupported database '{raw_name}'. Expected one of: {', '.join(sorted(DATABASE_FOLDERS))}."
    )


def normalize_bucket(raw_bucket: str) -> str:
    bucket = raw_bucket.strip()
    if bucket.startswith("s3://"):
        bucket = bucket[5:]
    return bucket.strip("/")


def parse_bucket_overrides(items: Iterable[str]) -> dict[str, str]:
    overrides: dict[str, str] = {}
    for item in items:
        if "=" not in item:
            raise ValueError(
                f"Invalid --bucket value '{item}'. Expected logical_database=bucket-or-prefix."
            )
        database, bucket = item.split("=", 1)
        overrides[normalize_database_name(database)] = normalize_bucket(bucket)
    return overrides


def csv_endpoint(owner: str, repo_database: str, ref: str, table_name: str) -> str:
    return f"https://www.dolthub.com/csv/{owner}/{repo_database}/{ref}/{table_name}"


def local_repo_path(repo_database: str) -> Path:
    return Path(ARGS.local_repo_root).resolve() / LOCAL_REPO_DIRS[repo_database]


def release_api_endpoint(owner: str, repo_database: str) -> str:
    return f"https://www.dolthub.com/api/v1alpha1/{owner}/{repo_database}/releases"


def open_url_with_retries(request: urllib.request.Request, attempts: int = 4):
    delay_seconds = 1
    last_error: Exception | None = None

    for attempt in range(1, attempts + 1):
        try:
            return urllib.request.urlopen(request, timeout=HTTP_TIMEOUT_SECONDS)
        except urllib.error.HTTPError as exc:
            last_error = exc
            if exc.code < 500 or attempt == attempts:
                raise
        except (urllib.error.URLError, TimeoutError, socket.timeout) as exc:
            last_error = exc
            if attempt == attempts:
                raise

        time.sleep(delay_seconds)
        delay_seconds *= 2

    if last_error is not None:
        raise last_error

    raise RuntimeError("Failed to open URL and no error was captured.")


def read_csv_rows(url: str) -> list[dict[str, str]]:
    request = urllib.request.Request(
        url,
        headers={"user-agent": "tuva-dolthub-publisher/1.0"},
    )
    with open_url_with_retries(request) as response:
        decoded = response.read().decode("utf-8")
    return list(csv.DictReader(decoded.splitlines()))


@lru_cache(maxsize=None)
def read_release_rows(owner: str, repo_database: str) -> list[dict[str, str]]:
    request = urllib.request.Request(
        release_api_endpoint(owner, repo_database),
        headers={"user-agent": "tuva-dolthub-publisher/1.0"},
    )
    with open_url_with_retries(request) as response:
        decoded = json.loads(response.read().decode("utf-8"))

    return decoded.get("releases", [])


@lru_cache(maxsize=None)
def resolve_dolthub_csv_ref(owner: str, repo_database: str, ref: str) -> str:
    releases = read_release_rows(owner, repo_database)
    for release in releases:
        if release.get("release_tag") == ref:
            return release["release_commit_sha"]
    return ref


def read_local_sql_csv(repo_database: str, query: str) -> list[dict[str, str]]:
    repo_path = local_repo_path(repo_database)
    result = subprocess.run(
        ["dolt", "sql", "-r", "csv", "-q", query],
        cwd=str(repo_path),
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    return list(csv.DictReader(result.stdout.splitlines()))


def sql_string_literal(value: str) -> str:
    return "'" + value.replace("\\", "\\\\").replace("'", "\\'") + "'"


def quote_identifier(identifier: str) -> str:
    return f"`{identifier.replace('`', '``')}`"


def get_local_header_columns(repo_database: str, table_name: str, local_ref: str | None = None) -> list[str]:
    repo_path = local_repo_path(repo_database)
    table_reference = quote_identifier(table_name)
    if local_ref:
        table_reference = f"{table_reference} AS OF {sql_string_literal(local_ref)}"
    result = subprocess.run(
        ["dolt", "sql", "-r", "csv", "-q", f"select * from {table_reference} limit 0"],
        cwd=str(repo_path),
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    reader = csv.reader(result.stdout.splitlines())
    header_columns = next(reader, [])
    return [column for column in header_columns if column != "__pk"]


def build_local_export_query(table_name: str, columns: list[str], local_ref: str | None = None) -> str:
    projected_columns = [
        f"IFNULL(CAST({quote_identifier(column)} AS CHAR), '\\\\N') AS {quote_identifier(column)}"
        for column in columns
    ]
    table_reference = quote_identifier(table_name)
    if local_ref:
        table_reference = f"{table_reference} AS OF {sql_string_literal(local_ref)}"
    return f"select {', '.join(projected_columns)} from {table_reference}"


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def iter_seed_configs(node, *, path: list[str] | None = None):
    if path is None:
        path = []

    if isinstance(node, dict):
        if "+post-hook" in node and path:
            yield path[-1], node["+post-hook"]
        for key, value in node.items():
            yield from iter_seed_configs(value, path=path + [key])
    elif isinstance(node, list):
        for item in node:
            yield from iter_seed_configs(item, path=path)


def normalize_column_type_expression(expression: str) -> str:
    return " ".join(expression.lower().split())


def is_date_type(expression: str) -> bool:
    normalized = normalize_column_type_expression(expression)
    return "date" in normalized and "datetime" not in normalized and "timestamp" not in normalized


def load_seed_column_types() -> dict[str, set[str]]:
    seed_column_types: dict[str, set[str]] = {}

    for path in sorted((repo_root() / "seeds").rglob("*.yml")):
        document = yaml.safe_load(path.read_text()) or {}
        for seed in document.get("seeds", []):
            config = seed.get("config", {})
            column_types = config.get("column_types", {})
            date_columns = {
                column_name
                for column_name, expression in column_types.items()
                if is_date_type(str(expression))
            }
            seed_column_types[seed["name"]] = date_columns

    integration_seed_path = repo_root() / "integration_tests" / "seeds" / "_seeds.yml"
    document = yaml.safe_load(integration_seed_path.read_text()) or {}
    for seed in document.get("seeds", []):
        config = seed.get("config", {})
        column_types = config.get("column_types", {})
        date_columns = {
            column_name
            for column_name, expression in column_types.items()
            if is_date_type(str(expression))
        }
        seed_column_types[seed["name"]] = date_columns

    return seed_column_types


def build_external_date_column_map() -> dict[tuple[str, str], set[str]]:
    seed_column_types = load_seed_column_types()
    external_date_columns: dict[tuple[str, str], set[str]] = {}

    dbt_project = yaml.safe_load((repo_root() / "dbt_project.yml").read_text()) or {}
    for seed_model_name, hook in iter_seed_configs(dbt_project.get("seeds", {})):
        match = HOOK_PATTERN.search(str(hook))
        if not match:
            continue
        database, pattern = match.groups()
        table_name = Path(pattern).stem
        repo_database = DATABASE_FOLDERS[normalize_database_name(database)]
        external_date_columns[(repo_database, table_name)] = set(
            seed_column_types.get(seed_model_name, set())
        )

    for table_name, seed_model_name in SYNTHETIC_TABLE_TO_SEED_MODEL.items():
        external_date_columns[("synthetic-data", table_name)] = set(
            seed_column_types.get(seed_model_name, set())
        )

    return external_date_columns


def normalize_date_value(value: str) -> str:
    if value in {"", "\\N"}:
        return value
    match = DATE_VALUE_PATTERN.match(value)
    if match:
        return match.group(1)
    return value


def normalize_row(row: list[str], header: list[str], date_columns: set[str]) -> list[str]:
    if not date_columns:
        return row

    normalized = list(row)
    for index, column_name in enumerate(header):
        if column_name in date_columns and index < len(normalized):
            normalized[index] = normalize_date_value(normalized[index])
    return normalized


def normalize_external_asset_header(asset: TableAsset, source_header: list[str]) -> list[str]:
    return [column for column in source_header if column != "__pk"]


def normalize_external_asset_row(
    asset: TableAsset,
    source_header: list[str],
    target_header: list[str],
    row: list[str],
) -> list[str]:
    row_map = dict(zip(source_header, row))
    return [row_map.get(column, "") for column in target_header]


def write_normalized_csv_to_gzip(reader, destination: Path, asset: TableAsset, date_columns: set[str]) -> int:
    row_count = 0
    source_header: list[str] | None = None
    output_header: list[str] | None = None

    with gzip.open(destination, "wt", encoding="utf-8", newline="") as gzip_file:
        writer = csv.writer(gzip_file, lineterminator="\n")
        for row in reader:
            if source_header is None:
                source_header = row
                output_header = normalize_external_asset_header(asset, source_header)
                writer.writerow(output_header)
                continue

            assert output_header is not None
            normalized_row = normalize_external_asset_row(asset, source_header, output_header, row)
            writer.writerow(normalize_row(normalized_row, output_header, date_columns))
            row_count += 1

    return row_count


def count_rows_in_gzip_csv(path: Path) -> int:
    row_count = 0
    with gzip.open(path, "rt", encoding="utf-8", newline="") as gzip_file:
        reader = csv.reader(gzip_file)
        next(reader, None)
        for _ in reader:
            row_count += 1
    return row_count


EXTERNAL_DATE_COLUMNS = build_external_date_column_map()


def get_assets_for_database(logical_database: str, owner: str, ref: str) -> list[TableAsset]:
    repo_database = DATABASE_FOLDERS[logical_database]
    if ARGS.source == "local":
        catalog_query = "select * from asset_table_catalog"
        if ARGS.local_ref:
            catalog_query += f" AS OF {sql_string_literal(ARGS.local_ref)}"
        catalog_rows = read_local_sql_csv(repo_database, catalog_query)
    else:
        catalog_ref = resolve_dolthub_csv_ref(owner, repo_database, ref)
        catalog_url = csv_endpoint(owner, repo_database, catalog_ref, "asset_table_catalog")
        catalog_rows = read_csv_rows(catalog_url)

    assets = [
        TableAsset(
            logical_database=logical_database,
            repo_database=repo_database,
            table_name=row["table_name"],
            expected_rows=int(row["row_count"]),
        )
        for row in catalog_rows
    ]
    assets.append(
        TableAsset(
            logical_database=logical_database,
            repo_database=repo_database,
            table_name="asset_table_catalog",
            expected_rows=len(catalog_rows),
        )
    )
    if ARGS.table:
        selected_tables = {table.strip() for table in ARGS.table if table.strip()}
        assets = [asset for asset in assets if asset.table_name in selected_tables]

    return sorted(assets, key=lambda asset: asset.table_name)


def ensure_upload_prerequisites() -> None:
    if shutil.which("aws") is None:
        raise RuntimeError("AWS CLI is required for upload mode but was not found in PATH.")

    subprocess.run(
        ["aws", "sts", "get-caller-identity"],
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )


def download_asset(asset: TableAsset, destination: Path, attempts: int = 4) -> int:
    if ARGS.source == "local":
        return download_local_asset(asset, destination)

    source_ref = resolve_dolthub_csv_ref(ARGS.owner, asset.repo_database, ARGS.ref)
    request = urllib.request.Request(
        csv_endpoint(ARGS.owner, asset.repo_database, source_ref, asset.table_name),
        headers={"user-agent": "tuva-dolthub-publisher/1.0"},
    )

    destination.parent.mkdir(parents=True, exist_ok=True)

    delay_seconds = 1
    last_error: Exception | None = None
    date_columns = EXTERNAL_DATE_COLUMNS.get((asset.repo_database, asset.table_name), set())
    for attempt in range(1, attempts + 1):
        try:
            with open_url_with_retries(request) as response:
                text_response = io.TextIOWrapper(response, encoding="utf-8", newline="")
                row_count = write_normalized_csv_to_gzip(
                    csv.reader(text_response),
                    destination,
                    asset,
                    date_columns,
                )

            return row_count
        except (
            csv.Error,
            http.client.IncompleteRead,
            TimeoutError,
            socket.timeout,
            urllib.error.HTTPError,
            urllib.error.URLError,
            UnicodeDecodeError,
        ) as exc:
            last_error = exc
            if destination.exists():
                destination.unlink()
            if isinstance(exc, urllib.error.HTTPError) and exc.code < 500:
                raise
            if attempt == attempts:
                raise
            time.sleep(delay_seconds)
            delay_seconds *= 2

    if last_error is not None:
        raise last_error

    raise RuntimeError("Failed to download asset and no error was captured.")


def download_local_asset(asset: TableAsset, destination: Path) -> int:
    repo_path = local_repo_path(asset.repo_database)
    destination.parent.mkdir(parents=True, exist_ok=True)
    columns = get_local_header_columns(asset.repo_database, asset.table_name, ARGS.local_ref)
    query = build_local_export_query(asset.table_name, columns, ARGS.local_ref)

    process = subprocess.Popen(
        ["dolt", "sql", "-r", "csv", "-q", query],
        cwd=str(repo_path),
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )

    date_columns = EXTERNAL_DATE_COLUMNS.get((asset.repo_database, asset.table_name), set())
    try:
        assert process.stdout is not None
        row_count = write_normalized_csv_to_gzip(
            csv.reader(process.stdout),
            destination,
            asset,
            date_columns,
        )
    finally:
        stderr = process.communicate()[1]

    if process.returncode != 0:
        if destination.exists():
            destination.unlink()
        raise RuntimeError(
            f"Local export failed for {asset.repo_database}.{asset.table_name}: {stderr.strip()}"
        )

    return row_count


def upload_asset(path: Path, destination_uri: str) -> None:
    subprocess.run(
        ["aws", "s3", "cp", str(path), destination_uri, "--only-show-errors"],
        check=True,
    )


def build_manifest_entry(asset: TableAsset, bucket: str, actual_rows: int, staged_path: Path) -> dict[str, str | int]:
    destination_uri = f"s3://{bucket}/{asset.relative_key}"
    if ARGS.source == "local":
        source_reference = f"{local_repo_path(asset.repo_database)}/{asset.table_name}"
        if ARGS.local_ref:
            source_reference = f"{source_reference}@{ARGS.local_ref}"
    else:
        source_reference = csv_endpoint(ARGS.owner, asset.repo_database, ARGS.ref, asset.table_name)
    return {
        "logical_database": asset.logical_database,
        "repo_database": asset.repo_database,
        "table_name": asset.table_name,
        "expected_rows": asset.expected_rows,
        "actual_rows": actual_rows,
        "source_url": source_reference,
        "staged_path": str(staged_path),
        "destination_uri": destination_uri,
    }


def write_manifest(manifest: list[dict[str, str | int]], manifest_path: Path) -> None:
    manifest_path.parent.mkdir(parents=True, exist_ok=True)
    manifest_path.write_text(json.dumps(manifest, indent=2) + "\n")


def main() -> int:
    selected_databases = (
        [normalize_database_name(database) for database in ARGS.database]
        if ARGS.database
        else list(DATABASE_FOLDERS)
    )
    bucket_overrides = parse_bucket_overrides(ARGS.bucket)

    if ARGS.keep_staged_files and not ARGS.stage_dir:
        raise ValueError("--keep-staged-files requires --stage-dir.")
    if ARGS.local_ref and ARGS.source != "local":
        raise ValueError("--local-ref can only be used with --source local.")

    if not ARGS.dry_run and not ARGS.download_only:
        ensure_upload_prerequisites()

    stage_root_path: Path | None = None
    temporary_directory: tempfile.TemporaryDirectory[str] | None = None
    if ARGS.stage_dir:
        stage_root_path = Path(ARGS.stage_dir).resolve()
        stage_root_path.mkdir(parents=True, exist_ok=True)
    elif not ARGS.dry_run:
        temporary_directory = tempfile.TemporaryDirectory(prefix="tuva-dolthub-publish-")
        stage_root_path = Path(temporary_directory.name)

    manifest: list[dict[str, str | int]] = []

    try:
        for logical_database in selected_databases:
            repo_database = DATABASE_FOLDERS[logical_database]
            bucket = bucket_overrides.get(logical_database, DEFAULT_BUCKET)
            assets = get_assets_for_database(logical_database, ARGS.owner, ARGS.ref)

            for asset in assets:
                staged_path = (
                    Path("/dev/null")
                    if stage_root_path is None
                    else stage_root_path / asset.relative_key
                )

                if ARGS.dry_run:
                    manifest.append(build_manifest_entry(asset, bucket, asset.expected_rows, staged_path))
                    continue

                if staged_path.exists():
                    actual_rows = count_rows_in_gzip_csv(staged_path)
                    if actual_rows == asset.expected_rows:
                        print(
                            f"reusing staged {asset.repo_database}.{asset.table_name} "
                            f"({actual_rows} rows) from {staged_path}",
                            flush=True,
                        )
                    else:
                        print(
                            f"discarding incomplete staged file for {asset.repo_database}.{asset.table_name}: "
                            f"expected {asset.expected_rows} rows, found {actual_rows}",
                            flush=True,
                        )
                        staged_path.unlink()
                        print(
                            f"downloading {asset.repo_database}.{asset.table_name} "
                            f"from {ARGS.ref} to {staged_path}",
                            flush=True,
                        )
                        actual_rows = download_asset(asset, staged_path)
                else:
                    print(
                        f"downloading {asset.repo_database}.{asset.table_name} "
                        f"from {ARGS.ref} to {staged_path}",
                        flush=True,
                    )
                    actual_rows = download_asset(asset, staged_path)

                if actual_rows != asset.expected_rows:
                    raise RuntimeError(
                        f"Row count mismatch for {asset.repo_database}.{asset.table_name}: "
                        f"expected {asset.expected_rows}, got {actual_rows}."
                    )

                entry = build_manifest_entry(asset, bucket, actual_rows, staged_path)
                manifest.append(entry)

                if not ARGS.download_only:
                    upload_asset(staged_path, entry["destination_uri"])

                print(
                    f"published {asset.repo_database}.{asset.table_name} "
                    f"({actual_rows} rows) -> {entry['destination_uri']}"
                    if not ARGS.download_only
                    else f"downloaded {asset.repo_database}.{asset.table_name} ({actual_rows} rows)",
                    flush=True,
                )

        if stage_root_path is not None:
            write_manifest(manifest, stage_root_path / "publish-manifest.json")
        else:
            print(json.dumps(manifest, indent=2))
    finally:
        if temporary_directory is not None and not ARGS.keep_staged_files:
            temporary_directory.cleanup()

    return 0


if __name__ == "__main__":
    try:
        ARGS = parse_args()
        ARGS.version = normalize_version(ARGS.version)
        sys.exit(main())
    except (ValueError, RuntimeError, urllib.error.URLError, subprocess.CalledProcessError) as exc:
        print(str(exc), file=sys.stderr)
        sys.exit(1)
